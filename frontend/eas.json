{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://bizcore-v2.fly.dev"
      },
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://bizcore-v2.fly.dev",
        "NODE_ENV": "production"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "hooks": {
        "preBuild": {
          "commands": [
            "npm run security:audit"
          ]
        },
        "postInstall": {
          "commands": [
            "npm audit --audit-level=high"
          ]
        }
      }
    }
  }
}
